    "vite": "^8.0.7",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "preinstall": "npx --yes only-allow yarn",
    "postinstall": "node scripts/ensure-splainer-search-dist.mjs",
    "test": "yarn build:islands && vitest run",
    "test:new": "vitest run",
    "test:new:watch": "vitest",
    "stryker": "stryker run",
    "stryker:full": "stryker run --force",
    "stryker:dry": "stryker run --dryRunOnly",
    "test:e2e": "yarn build:islands && playwright test",
    "test:e2e:ui": "yarn build:islands && playwright test --ui",
    "dev:vite": "vite",
    "build:islands": "node scripts/build-islands.mjs",
    "build:islands:watch": "node scripts/build-islands.mjs --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "browserslist": [
    "last 1 version",
    "> 1%",
    "maintained node versions",
    "not dead"
  ]
}
